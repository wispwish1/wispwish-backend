{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/*.js": {
      "includeFiles": [
        "server.js",
        "config/**",
        "gift-platform/**",
        "knowledge/**",
        "middleware/**",
        "models/**",
        "routes/**",
        "services/**",
        "utils/**"
      ]
    }
  }
}
